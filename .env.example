# ---------------------------------------------------------------------------
# Crashscope — root .env.example
#
# This file is a one-stop unified example for local development of the
# `@crashscope/server` package. The canonical copy lives at
# `packages/server/.env.example`; this root mirror exists so a fresh clone
# can get started without hunting through the monorepo.
#
# To use:
#   cp .env.example packages/server/.env.local
#   # then edit packages/server/.env.local with your real credentials
#
# Next.js auto-loads `.env.local` from the server package in `pnpm dev`.
# Variables required for the surfaces you actually use. See per-section
# comments.
#
# The CLI does NOT read this file — it uses `~/.crashscope/config.json`,
# generated by running `crashscope init`.
# ---------------------------------------------------------------------------

# ----- Anthropic ----------------------------------------------------------
# REQUIRED for: GET /api/triage (bearer-authed REST endpoint) and
#               POST /api/slack/command (the Slack bot).
# NOT REQUIRED for: POST /api/triage (the public demo) — visitors bring their
#                   own key in the request body; the server never reads this
#                   env var on that path.
#
# Server mode does NOT support the Claude Code subscription path — an API key
# is mandatory for the env-driven routes above.
ANTHROPIC_API_KEY=sk-ant-...

# ----- REST API auth ------------------------------------------------------
# Bearer token clients must send to /api/triage as
#   `Authorization: Bearer <CRASHSCOPE_API_TOKEN>`.
# Generate with: `openssl rand -hex 32`.
CRASHSCOPE_API_TOKEN=replace-me-with-a-long-random-string

# ----- Error provider -----------------------------------------------------
# Pick ONE of: sentry | rollbar | bugsnag | honeybadger.
ERROR_PROVIDER=sentry

# Sentry
SENTRY_TOKEN=...
SENTRY_ORG=your-org-slug
SENTRY_PROJECT=your-project-slug

# Rollbar (use these if ERROR_PROVIDER=rollbar)
# ROLLBAR_TOKEN=...
# ROLLBAR_PROJECT=optional-project-slug

# Bugsnag (use these if ERROR_PROVIDER=bugsnag)
# BUGSNAG_TOKEN=...
# BUGSNAG_ORGANIZATION_ID=...
# BUGSNAG_PROJECT_ID=...

# Honeybadger (use these if ERROR_PROVIDER=honeybadger)
# HONEYBADGER_TOKEN=...
# HONEYBADGER_PROJECT=...

# ----- Session provider ---------------------------------------------------
# Pick ONE of: posthog | logrocket.
SESSION_PROVIDER=posthog

# PostHog
POSTHOG_API_KEY=phx_...
POSTHOG_PROJECT_ID=...
# Optional: override the API host (e.g. EU cloud or self-hosted).
# POSTHOG_HOST=https://app.posthog.com

# LogRocket (use these if SESSION_PROVIDER=logrocket)
# LOGROCKET_API_KEY=...
# LOGROCKET_APP_SLUG=org/app

# ----- Slack bot ----------------------------------------------------------
# CONDITIONAL — only required if you expose /api/slack/* routes. Skip both if
# you only run GET /api/triage or the public POST demo.
#   - SLACK_SIGNING_SECRET verifies Slack request signatures (required for
#     any /api/slack/* route).
#   - SLACK_BOT_TOKEN is reserved for future use; no `chat.postMessage` is
#     called yet, but populate it now if you plan to enable richer responses.
SLACK_SIGNING_SECRET=...
SLACK_BOT_TOKEN=xoxb-...
