{
  "name": "crashscope-monorepo",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "AI-powered error triage that bridges error trackers and session analytics.",
  "license": "MIT",
  "packageManager": "pnpm@9.12.0",
  "engines": {
    "node": ">=18.18"
  },
  "scripts": {
    "build": "tsc -b",
    "typecheck": "tsc -b --noEmit",
    "clean": "tsc -b --clean && rimraf 'packages/*/dist' 'packages/*/*.tsbuildinfo'",
    "lint": "eslint \"packages/*/src/**/*.ts\"",
    "format": "prettier --write \"packages/*/src/**/*.{ts,tsx,json,md}\" \"*.{json,md,yaml,yml}\"",
    "format:check": "prettier --check \"packages/*/src/**/*.{ts,tsx,json,md}\" \"*.{json,md,yaml,yml}\""
  },
  "devDependencies": {
    "@types/node": "^22.7.0",
    "@typescript-eslint/eslint-plugin": "^8.8.0",
    "@typescript-eslint/parser": "^8.8.0",
    "eslint": "^9.11.0",
    "eslint-config-prettier": "^9.1.0",
    "prettier": "^3.3.3",
    "rimraf": "^6.0.1",
    "typescript": "^5.6.0"
  }
}
