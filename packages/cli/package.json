{
  "name": "@pradhankukiran/crashscope",
  "version": "0.1.0",
  "description": "AI-powered error triage CLI: pulls errors from Sentry / Rollbar / Bugsnag / Honeybadger, joins them with PostHog or LogRocket session replays, and uses Claude to produce ranked, actionable triage reports.",
  "keywords": [
    "ai",
    "claude",
    "anthropic",
    "triage",
    "error-tracking",
    "session-replay",
    "sentry",
    "posthog",
    "rollbar",
    "bugsnag",
    "honeybadger",
    "logrocket",
    "developer-tools",
    "cli",
    "observability"
  ],
  "homepage": "https://github.com/pradhankukiran/crashscope#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/pradhankukiran/crashscope.git",
    "directory": "packages/cli"
  },
  "bugs": {
    "url": "https://github.com/pradhankukiran/crashscope/issues"
  },
  "author": "Kiran Kumar Pradhan <kiran@ecorrouge.com>",
  "license": "MIT",
  "type": "module",
  "bin": {
    "crashscope": "./bin/crashscope"
  },
  "main": "./dist/index.js",
  "files": [
    "bin",
    "dist",
    "README.md",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc -b",
    "typecheck": "tsc -b --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@pradhankukiran/crashscope-core": "workspace:*",
    "commander": "^12.1.0",
    "@inquirer/prompts": "^7.0.0",
    "chalk": "^5.3.0",
    "boxen": "^8.0.0",
    "ora": "^8.1.0",
    "zod": "^4.0.0"
  },
  "devDependencies": {
    "typescript": "^5.6.0",
    "@types/node": "^22.0.0"
  },
  "engines": {
    "node": ">=20"
  },
  "publishConfig": {
    "access": "public"
  }
}
