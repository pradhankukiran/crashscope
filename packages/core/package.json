{
  "name": "@pradhankukiran/crashscope-core",
  "version": "0.1.0",
  "description": "Core types, schemas, and Claude investigation loop powering the crashscope CLI and server.",
  "keywords": [
    "ai",
    "claude",
    "anthropic",
    "triage",
    "error-tracking",
    "session-replay",
    "sentry",
    "posthog",
    "rollbar",
    "bugsnag",
    "honeybadger",
    "logrocket",
    "developer-tools",
    "cli",
    "observability"
  ],
  "homepage": "https://github.com/pradhankukiran/crashscope#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/pradhankukiran/crashscope.git",
    "directory": "packages/core"
  },
  "bugs": {
    "url": "https://github.com/pradhankukiran/crashscope/issues"
  },
  "author": "Kiran Kumar Pradhan <kiran@ecorrouge.com>",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "README.md"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./types": {
      "types": "./dist/types/index.d.ts",
      "import": "./dist/types/index.js",
      "default": "./dist/types/index.js"
    },
    "./errors": {
      "types": "./dist/errors.d.ts",
      "import": "./dist/errors.js",
      "default": "./dist/errors.js"
    },
    "./agent": {
      "types": "./dist/agent/index.d.ts",
      "import": "./dist/agent/index.js",
      "default": "./dist/agent/index.js"
    },
    "./adapters": {
      "types": "./dist/adapters/index.d.ts",
      "import": "./dist/adapters/index.js",
      "default": "./dist/adapters/index.js"
    },
    "./adapters/errors": {
      "types": "./dist/adapters/errors/index.d.ts",
      "import": "./dist/adapters/errors/index.js",
      "default": "./dist/adapters/errors/index.js"
    },
    "./adapters/sessions": {
      "types": "./dist/adapters/sessions/index.d.ts",
      "import": "./dist/adapters/sessions/index.js",
      "default": "./dist/adapters/sessions/index.js"
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "tsc -b",
    "typecheck": "tsc -b --noEmit",
    "clean": "tsc -b --clean && rimraf dist *.tsbuildinfo"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.3.142",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "rimraf": "^6.0.1",
    "typescript": "^5.6.0"
  },
  "publishConfig": {
    "access": "public"
  }
}
