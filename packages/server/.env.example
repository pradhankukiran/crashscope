# ---------------------------------------------------------------------------
# Crashscope server — example environment configuration.
#
# Copy this file to `.env.local` (Next.js auto-loads it in dev) or set these
# vars in your deployment platform (Vercel, Fly, etc.). Every variable below
# is required unless explicitly marked optional.
# ---------------------------------------------------------------------------

# ----- Anthropic ----------------------------------------------------------
# API key used to invoke Claude for triage on the server-controlled paths:
#   - GET /api/triage  (bearer-authed REST endpoint)
#   - POST /api/slack/command  (the Slack bot)
#
# The public landing-page demo (POST /api/triage) does NOT use this key — the
# visitor supplies their own Anthropic key in the request body, and the server
# never reads its own env var on that path.
#
# Server mode does NOT support the Claude Code subscription path; an API key
# is mandatory for the env-driven routes above.
ANTHROPIC_API_KEY=sk-ant-...

# ----- REST API auth ------------------------------------------------------
# Bearer token clients must send to /api/triage as
#   `Authorization: Bearer <CRASHSCOPE_API_TOKEN>`.
# Generate with: `openssl rand -hex 32`.
CRASHSCOPE_API_TOKEN=replace-me-with-a-long-random-string

# ----- Error provider -----------------------------------------------------
# Pick ONE of: sentry | rollbar | bugsnag | honeybadger.
ERROR_PROVIDER=sentry

# Sentry
SENTRY_TOKEN=...
SENTRY_ORG=your-org-slug
SENTRY_PROJECT=your-project-slug

# Rollbar (use these if ERROR_PROVIDER=rollbar)
# ROLLBAR_TOKEN=...
# ROLLBAR_PROJECT=optional-project-slug

# Bugsnag (use these if ERROR_PROVIDER=bugsnag)
# BUGSNAG_TOKEN=...
# BUGSNAG_ORGANIZATION_ID=...
# BUGSNAG_PROJECT_ID=...

# Honeybadger (use these if ERROR_PROVIDER=honeybadger)
# HONEYBADGER_TOKEN=...
# HONEYBADGER_PROJECT=...

# ----- Session provider ---------------------------------------------------
# Pick ONE of: posthog | logrocket.
SESSION_PROVIDER=posthog

# PostHog
POSTHOG_API_KEY=phx_...
POSTHOG_PROJECT_ID=...
# Optional: override the API host (e.g. EU cloud or self-hosted).
# POSTHOG_HOST=https://app.posthog.com

# LogRocket (use these if SESSION_PROVIDER=logrocket)
# LOGROCKET_API_KEY=...
# LOGROCKET_APP_SLUG=org/app

# ----- Slack bot ----------------------------------------------------------
# Required for /api/slack/command and /api/slack/events.
SLACK_SIGNING_SECRET=...
SLACK_BOT_TOKEN=xoxb-...
